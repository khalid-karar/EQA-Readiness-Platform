# EQA Readiness Platform — environment variable reference.
#
# Copy this file to `.env` (which is git-ignored) and fill in real values for
# local development. NEVER commit real secrets. CI scans for leaked secrets.
# These variables document intent for upcoming steps; the Step 1 skeleton does
# not yet read most of them.

# --- Runtime -------------------------------------------------------------
NODE_ENV=development
PORT=3000

# --- Database (schema-per-tenant) ---------------------------------------
# Connection string for the platform database. Per-tenant isolation is applied
# in code via the tenant-scoped repositories, never by reaching the raw client.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/eqa

# --- Envelope encryption (KMS) ------------------------------------------
# Master key lives in the KMS; per-tenant data keys are encrypted by it.
# Plaintext keys never appear here or in any committed file.
KMS_PROVIDER=local-dev
KMS_MASTER_KEY_ID=local-dev-master
# Local dev only: base64 of a 32-byte master key for the LocalKms stub. If
# unset outside production, an ephemeral key is generated per process. In
# production a real KMS is used and a missing key is a hard error.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
KMS_MASTER_KEY=

# --- Tenancy -------------------------------------------------------------
# Header carrying the tenant slug on tenant-scoped requests (see middleware).
# Public routes (/health, /, /auth/*) require no tenant.
TENANT_HEADER=x-tenant-slug
# Comma-separated active tenant slugs for edge request gating (middleware).
TENANT_ALLOWLIST=seera-pilot,beta-co,demo-fresh

# --- Auth (Keycloak / OIDC, self-hosted in KSA) -------------------------
# Identity is verified through a swappable provider (Keycloak now, SAML later).
# Tenant + role are read from token claims and bound at authentication; they are
# never taken from request headers. MFA is mandatory.
KEYCLOAK_ISSUER=https://keycloak.internal/realms/eqa
KEYCLOAK_AUDIENCE=eqa-web
# Confidential client secret (Railway secret / local only — never commit).
KEYCLOAK_CLIENT_SECRET=
AUTH_SESSION_SECRET=
APP_URL=http://localhost:3000
# Dev-only UI toggles (View as / locale query overrides). Off in production.
EQA_DEV_VIEW_CONTROLS=
# Token claim names (defaults shown).
KEYCLOAK_TENANT_CLAIM=tenant
KEYCLOAK_ROLE_CLAIM=role
AUTH_SESSION_SECRET=

# --- AI layer (swappable, data must stay in Saudi Arabia) ---------------
# Selects the AI inference adapter (no vendor hardcoded; same port/adapter
# pattern as storage and jobs):
#   "local-stub"  — in-process stub for local/dev and tests (no network).
#   "local-llm"   — self-hosted Ollama on localhost (OpenAI-compatible API).
#   "in-kingdom"  — a self-hosted model inside the KSA environment (today's
#                   self-hosted adapter; future HUMAIN adapter). Requires an
#                   injected inference client; composed in code, not from env.
# There is deliberately NO value that selects an external/out-of-Kingdom API:
# external frontier APIs are not a usable path for client evidence (fails closed).
# Every model call is redacted, data-minimized, run as a tenant-scoped job, and
# its provenance (prompt/rubric version, adapter, redacted input summary, output,
# timestamp) is audited.
AI_ADAPTER=local-stub
# Local Ollama (only when AI_ADAPTER=local-llm). Host must stay on-box (localhost).
AI_BASE_URL=http://localhost:11434
AI_MODEL=llama3.2

# --- Object storage / evidence files ------------------------------------
# The evidence object store is swappable by config (no hardcoded vendor):
#   "memory" — in-process store for local/dev and tests.
#   "s3"     — S3-compatible KSA object store (bucket/region are config).
# Uploaded files are validated (type allowlist + size limit), encrypted at rest
# with the per-tenant data key, and held in quarantine until a malware-scan
# background job clears them. Downloads use short-lived signed URLs.
STORAGE_DRIVER=memory
STORAGE_BUCKET=eqa-evidence
STORAGE_REGION=me-central-1
# Max upload size (bytes) and comma-separated content-type allowlist.
STORAGE_MAX_BYTES=26214400
STORAGE_ALLOWED_TYPES=application/pdf,image/png,image/jpeg
# Secret used to sign short-lived evidence download URLs, and their TTL.
STORAGE_SIGNING_SECRET=
STORAGE_DOWNLOAD_TTL_SECONDS=300
# S3-compatible endpoint (MinIO in docker-compose.dev.yml).
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_FORCE_PATH_STYLE=true

# --- Malware scanning (ClamAV) ----------------------------------------
#   "stub"   — always-clean in-process scanner (local dev without clamd).
#   "clamav" — TCP scan via clamd (Compose service on port 3310).
MALWARE_SCANNER=stub
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310

# --- Background jobs / queue --------------------------------------------
# The job queue backend is swappable by config (no hardcoded vendor):
#   "memory" — in-process adapter for local/dev and tests (no Redis needed).
#   "bullmq" — production path on Redis + BullMQ (Redis hosted in KSA).
# All long-running work (malware scanning, AI review, document processing,
# exports) runs through tenant-scoped jobs, never synchronous request handlers.
JOB_QUEUE_DRIVER=memory
JOB_QUEUE_NAME=eqa-jobs
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
