# Local dev — synthetic data only. Copy to .env.local (gitignored; never commit).
# Next.js reads apps/web/.env.local — copy this file there too (see infra/DEV.md).

# --- Database (Compose postgres on host port 5433) -----------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5433/eqa

# --- Auth (local Keycloak from docker-compose.dev.yml) -------------------
KEYCLOAK_ISSUER=http://localhost:8080/realms/eqa
KEYCLOAK_AUDIENCE=eqa-web
KEYCLOAK_CLIENT_SECRET=eqa-web-local-dev-secret
AUTH_SESSION_SECRET=local-dev-session-secret-32-bytes-minimum
APP_URL=http://localhost:3000

# --- Tenancy -------------------------------------------------------------
TENANT_ALLOWLIST=seera-pilot,beta-co,demo-fresh

# --- Object storage (MinIO in Compose) -----------------------------------
STORAGE_DRIVER=s3
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=eqa-evidence
STORAGE_FORCE_PATH_STYLE=true

# --- Malware scanning (ClamAV in Compose) --------------------------------
MALWARE_SCANNER=clamav
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310

# --- AI (Ollama on host — not in Compose) ----------------------------------
AI_ADAPTER=local-llm
AI_BASE_URL=http://localhost:11434
AI_MODEL=qwen2.5:7b

# --- Dev UI toggles --------------------------------------------------------
EQA_DEV_VIEW_CONTROLS=true
