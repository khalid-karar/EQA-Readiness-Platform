# Local dev — copy to `.env.local` (gitignored). Synthetic credentials only.
# Bring up the stack first: docker compose -f docker-compose.dev.yml up -d
# See infra/DEV.md for full steps.

# --- Database (docker-compose.dev.yml postgres service) -----------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/eqa

# --- Auth (Keycloak eqa realm, confidential client eqa-web) -------------
KEYCLOAK_ISSUER=http://localhost:8080/realms/eqa
KEYCLOAK_AUDIENCE=eqa-web
KEYCLOAK_CLIENT_SECRET=eqa-web-local-dev-secret
AUTH_SESSION_SECRET=local-dev-session-secret-at-least-32-bytes
APP_URL=http://localhost:3000
EQA_DEV_VIEW_CONTROLS=true

# --- Object storage (MinIO S3-compatible) -------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=eqa-evidence
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# --- Malware scanning (ClamAV clamd) ------------------------------------
CLAMD_HOST=localhost
CLAMD_PORT=3310

# --- AI (Ollama — run natively on the host, not in Compose) -------------
AI_BASE_URL=http://localhost:11434
