# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.next/
out/
*.tsbuildinfo

# Test / coverage
coverage/
.vitest/
apps/web/test-results/
apps/web/playwright-report/

# Pinned Chromium cache (provisioned at install/image-build — see packages/workflows/CHROMIUM.md)
packages/workflows/.chromium-cache/

# Optional local poppler download for baseline generation on Windows
tools/.poppler/

# Secrets — never commit real secrets (see .env.example for required vars)
.env
.env.*
!.env.example
!.env.railway

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Local tool binaries (e.g. gitleaks downloaded for local scans)
.tools/

# Generated sample renders (regenerate via pnpm generate:sample-pack)
samples/*.pdf
samples/*.png
