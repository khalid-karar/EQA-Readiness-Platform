{
  "name": "eqa-readiness-platform",
  "version": "0.0.0",
  "private": true,
  "description": "EQA Readiness Platform — multi-tenant SaaS monorepo",
  "packageManager": "pnpm@10.21.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @eqa/web dev",
    "build": "pnpm -r run build",
    "start": "pnpm --filter @eqa/web start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "pnpm -r run type-check",
    "test": "vitest run",
    "test:e2e": "pnpm --filter @eqa/web test:e2e",
    "test:pdf-determinism": "vitest run packages/workflows/src/evidence-pack-pdf-determinism.test.ts",
    "test:watch": "vitest",
    "generate:sample-pack": "tsx tools/generate-sample-pack.ts",
    "generate:evidence-pack-visual-baselines": "tsx tools/generate-evidence-pack-visual-baselines.ts",
    "generate:evidence-pack-baseline": "pnpm generate:evidence-pack-visual-baselines",
    "generate:mixed-script-torture-baseline": "pnpm generate:evidence-pack-visual-baselines",
    "provision:chromium": "pnpm --filter @eqa/workflows run provision-chromium",
    "rasterize:sample-pack": "tsx tools/rasterize-sample-pack.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@napi-rs/canvas": "^1.0.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-boundaries": "^5.0.1",
    "globals": "^15.13.0",
    "pdfjs-dist": "^6.0.227",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
