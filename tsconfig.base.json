{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,

    "baseUrl": ".",
    "paths": {
      "@eqa/db": ["packages/db/src/index.ts"],
      "@eqa/auth": ["packages/auth/src/index.ts"],
      "@eqa/audit-log": ["packages/audit-log/src/index.ts"],
      "@eqa/tenant": ["packages/tenant/src/index.ts"],
      "@eqa/storage": ["packages/storage/src/index.ts"],
      "@eqa/ai": ["packages/ai/src/index.ts"],
      "@eqa/content": ["packages/content/src/index.ts"],
      "@eqa/workflows": ["packages/workflows/src/index.ts"],
      "@eqa/jobs": ["packages/jobs/src/index.ts"],
      "@eqa/crypto": ["packages/crypto/src/index.ts"]
    }
  }
}
